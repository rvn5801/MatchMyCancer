# MatchMyCancer.ai — Environment Variables
# Copy to backend/.env and fill in values. NEVER commit the filled-in .env.

# ── LLM (required) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ── Vector store (clinical-trial index) ─────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Redis (spend ceiling, usage metrics, readiness) ─────────────
# Local: host/port. Managed (Upstash/etc): set REDIS_URL instead — it
# wins over host/port and supports TLS + auth, e.g. rediss://default:pw@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=

# ── App ─────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
ANALYZE_ENABLED=true
SPEND_CEILING_USD=50.0
TRIAL_REFRESH_ENABLED=false
LOG_LEVEL=INFO
